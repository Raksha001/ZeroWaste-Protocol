# ——————————————————————————————————
# ZeroWaste Protocol — Environment Variables
# ——————————————————————————————————

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OKX Onchain OS API Credentials (from https://web3.okx.com/onchain-os/dev-portal)
OKX_API_KEY=your_okx_api_key_here
OKX_SECRET_KEY=your_okx_secret_key_here
OKX_PASSPHRASE="your_okx_passphrase_here"
OKX_PROJECT_ID=your_okx_project_id_here

# Groq API Key (for LLaMA 3.3 NLP)
# Get yours from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Agent Wallet Address
# This is created/managed by the bot on /start. You don't need to set it manually,
# but can be used for reference in some mock scripts.
AGENT_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# ——————————————————————————————————
# Network Selection: "testnet" | "mainnet"
# ——————————————————————————————————
NETWORK=mainnet

# Deployer Wallet (for Hardhat testnet/mainnet contract deployment only)
# Insert a regular private key here that has OKB gas
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here

# X Layer Testnet (Chain ID: 1952)
XLAYER_TESTNET_RPC_URL=https://testrpc.xlayer.tech
XLAYER_TESTNET_CHAIN_ID=1952

# X Layer Mainnet (Chain ID: 196)
XLAYER_MAINNET_RPC_URL=https://okx-xlayer.rpc.blxrbdn.com
XLAYER_MAINNET_CHAIN_ID=196

# ——————————————————————————————————
# Mock Merchant & Feature Flags
# ——————————————————————————————————
MERCHANT_PORT=3001
MERCHANT_WALLET_ADDRESS=
MOCK_MODE=false

# Dust Sweeper Multicall contract address (deployed on X Layer)
DUST_SWEEPER_CONTRACT=0x1E52781EC86C99C972f30366dA493c780a54ED8c

# ——————————————————————————————————
# Deployment/Railway Settings
# ——————————————————————————————————
# Path to the onchainos binary
ONCHAINOS_PATH=/app/.local/bin/onchainos

# Storage paths for Railway Volumes
USER_DATA_DIR=/app/storage/data
HOME=/app/storage
